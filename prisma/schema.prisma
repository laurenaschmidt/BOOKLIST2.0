generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ReadingStatus {
  WANT_TO_READ
  CURRENTLY_READING
  FINISHED
}

enum LyricsType {
  INSTRUMENTAL
  LYRICAL
  MIXED
}

enum NotificationType {
  NEW_FOLLOWER
  NEW_PLAYLIST
}

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  passwordHash    String
  image           String?
  bio             String?
  favoriteArtists String[] @default([])
  createdAt       DateTime @default(now())

  books     UserBook[]
  playlists Playlist[]

  following Follow[] @relation("Following")
  followers Follow[] @relation("Followers")

  receivedNotifications Notification[] @relation("ReceivedNotifications")
  sentNotifications     Notification[] @relation("SentNotifications")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  followed    User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  recipient   User             @relation("ReceivedNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User             @relation("SentNotifications", fields: [actorId], references: [id], onDelete: Cascade)
  type        NotificationType
  playlistId  String?
  playlist    Playlist?        @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([recipientId, createdAt])
}

model Book {
  id            String   @id @default(cuid())
  googleBooksId String   @unique
  title         String
  authors       String[]
  description   String?
  coverUrl      String?
  genres        String[]
  pageCount     Int?
  publishedDate String?
  createdAt     DateTime @default(now())

  userEntries UserBook[]
  playlists   Playlist[]
}

model UserBook {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId     String
  book       Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  status     ReadingStatus @default(WANT_TO_READ)
  rating     Int?
  startedAt  DateTime?
  finishedAt DateTime?
  addedAt    DateTime      @default(now())

  @@unique([userId, bookId])
}

model Playlist {
  id          String      @id @default(cuid())
  title       String
  description String?
  lyricsType  LyricsType?
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId      String
  book        Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  songs         Song[]
  notifications Notification[]
}

model Song {
  id          String   @id @default(cuid())
  playlistId  String
  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  title       String
  artist      String
  url         String?
  albumArtUrl String?
  previewUrl  String?
  reason      String?
  order       Int      @default(0)
}
